{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "flaremo",
  "main": "./apps/worker/src/index.ts",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "assets": {
    "directory": "./apps/web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "flaremo",
      "database_id": "5a5094d8-efcc-4aef-909b-c8455358247d",
      "migrations_dir": "./migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ATTACHMENTS",
      "bucket_name": "flaremo-attachments"
    }
  ],
  "triggers": {
    "crons": ["17 3 * * *"]
  },
  "vars": {
    "FLAREMO_DEPLOY_REPOSITORY": "",
    "FLAREMO_SINGLE_USER_EMAIL": "owner@flaremo.local",
    "FLAREMO_SINGLE_USER_NAME": "FlareMo Owner"
  }
}
